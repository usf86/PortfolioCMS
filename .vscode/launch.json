{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (.NET) - Lancer",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/backend/src/PortfolioCMS.Api/bin/Debug/net8.0/PortfolioCMS.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/src/PortfolioCMS.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
